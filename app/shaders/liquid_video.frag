#include <flutter/runtime_effect.glsl>

uniform vec2 u_resolution;
uniform float u_time;

out vec4 fragColor;

// Функция для генерации шума (убирает "лесенки" на градиентах для OLED экранов)
float random(vec2 p) {
    return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
}

void main() {
    // 1. Нормализуем координаты (от 0.0 до 1.0)
    vec2 uv = FlutterFragCoord().xy / u_resolution;
    
    // Переводим в систему от -1.0 до 1.0 и корректируем пропорции экрана
    vec2 p = uv * 2.0 - 1.0;
    p.x *= u_resolution.x / u_resolution.y;

    // Замедляем время для элегантной плавности, как на видео
    float time = u_time * 0.25;

    // 2. ЖИДКОЕ ИСКАЖЕНИЕ (Domain Warping) - Уменьшаем для "прямоты" волн
    vec2 warp = vec2(0.0);
    warp.x = sin(p.y * 2.0 + time) * 0.2 + cos(p.x * 1.5 - time) * 0.15;
    warp.y = cos(p.x * 2.0 + time) * 0.2 + sin(p.y * 1.5 + time) * 0.15;

    // 3. СТРОГАЯ ДИАГОНАЛЬ
    // Точно 45 градусов
    float angle = -0.785398;
    float s = sin(angle);
    float c = cos(angle);
    mat2 rot = mat2(c, -s, s, c);
    
    // Применяем вращение к координатам, немного сглаживая искажением
    vec2 rp = rot * (p + warp * 0.25);

    // 4. ГЕНЕРАЦИЯ СКЛАДОК ШЕЛКА (Больше складок)
    // Увеличиваем коэффициенты умножения rp.x, чтобы получить "чуть больше" волн
    float flow = sin(rp.x * 6.0 - time * 1.5);             // Основные крупные складки
    flow += cos(rp.x * 11.0 + rp.y * 2.0 + time * 1.2) * 0.4; // Средние складки
    flow += sin(rp.x * 18.0 - time * 1.8) * 0.2;            // Мелкие глянцевые прожилки
    
    // Нормализуем значение в диапазон от 0.0 до 1.0 (амплитуда теперь от -1.6 до 1.6)
    float v = (flow / 3.2) + 0.5;

    // 5. ЦВЕТОВАЯ ПАЛИТРА (Сэмплировано прямо с вашего скриншота)
    vec3 colDark  = vec3(0.02, 0.10, 0.08); // Очень тёмный (тени)
    vec3 colBase  = vec3(0.04, 0.22, 0.14); // Насыщенный зелёный (база)
    vec3 colGlow  = vec3(0.00, 0.65, 0.42); // Яркий бирюзовый ореол
    vec3 colLight = vec3(0.35, 0.95, 0.65); // Светлый острый блик

    // 6. СМЕШИВАНИЕ ЦВЕТОВ (Создание объема)
    // Плавный переход от тени к базовому цвету
    vec3 color = mix(colDark, colBase, smoothstep(0.1, 0.45, v));
    
    // Добавление широкого яркого свечения (Glow)
    float glow = smoothstep(0.45, 0.75, v);
    color = mix(color, colGlow, glow);
    
    // ОСТРЫЙ БЛИК: секрет шелка. Делаем вершину волны очень яркой, но узкой
    float peak = smoothstep(0.85, 1.0, v);
    color = mix(color, colLight, pow(peak, 2.5)); // 2.5 делает блик еще более концентрированным и острым

    // 7. ФИНАЛЬНЫЕ ШТРИХИ
    // Легкая виньетка (затемнение по углам), чтобы сфокусировать внимание в центре
    float vignette = length(uv - 0.5) * 1.5;
    color *= 1.0 - vignette * 0.2;

    // Пленочный шум (предотвращает эффект "лесенки" на идеальных градиентах)
    float noise = (random(uv + fract(u_time)) - 0.5) * 0.04;
    color += noise;

    // Выводим на экран, ограничивая значения цвета от 0.0 до 1.0
    fragColor = vec4(clamp(color, 0.0, 1.0), 1.0);
}
